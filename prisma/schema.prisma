generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource database {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String
  username      String   @unique
  password      String?
  email         String    @unique
  emailVerified DateTime?
  image         String? 
  isAdmin       Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  jobProfile     JobProfile?
  participations Participation[]
  events         Event[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @database.Text
  access_token      String? @database.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @database.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model JobProfile {
  id     String  @id @default(uuid())
  userId String  @unique
  title  String?

  daysOfLeave     Int //days off per year
  daysOfSickLeave Int //sick leave per year

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([id])
}

model Event {
  id          String  @id @default(uuid())
  title       String
  image       String?
  description String?
  isApproved  Boolean @default(false)
  isYearly    Boolean @default(false)

  startAt DateTime
  endAt   DateTime

  location    String?
  locationUrl String?

  reference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  participations Participation[]
  createdByUser  User            @relation(fields: [createdBy], references: [id])

  @@index([title])
}

model Participation {
  id        String    @id @default(uuid())
  userId    String
  eventId   String?
  from      DateTime
  to        DateTime
  leaveType LeaveType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id])
  event Event? @relation(fields: [eventId], references: [id])

  @@index([userId, from, to])
  @@unique([userId, eventId])
  @@unique([userId, from, to])
  @@index([userId, eventId])
}

model Holiday {
  id          String   @id @default(uuid())
  date        DateTime
  description String?
  country     String?
  isGlobal    Boolean  @default(false)

  @@index([country])
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
}
