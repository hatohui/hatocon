generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource database {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String
  username      String   @unique
  password      String?
  email         String    @unique
  emailVerified DateTime?
  image         String? 
  isAdmin       Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts       Account[]
  sessions       Session[]
  jobProfile     JobProfile?
  participations Participation[]
  events         Event[]
  notifications  Notification[]
  joinRequests   JoinRequest[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @database.Text
  access_token      String? @database.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @database.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model JobProfile {
  id     String  @id @default(uuid())
  userId String  @unique
  title  String?

  daysOfLeave     Int //days off per year
  daysOfSickLeave Int //sick leave per year
  leaveCycleStart DateTime @default(now()) //when the leave year starts

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([id])
}

model Event {
  id          String  @id @default(uuid())
  title       String
  image       String?
  description String?
  isApproved  Boolean @default(false)
  isYearly    Boolean @default(false)
  visibility  EventVisibility @default(PUBLIC)

  startAt DateTime
  endAt   DateTime

  location    String?
  locationUrl String?

  reference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  participations     Participation[]
  invitees           EventInvitee[]
  createdByUser      User                @relation(fields: [createdBy], references: [id])
  participationGroups ParticipationGroup[]

  @@index([title])
}

model Participation {
  id        String    @id @default(uuid())
  userId    String
  eventId   String?
  groupId   String?
  from      DateTime
  to        DateTime
  leaveType LeaveType
  createdBy String?   // null = self, otherwise the admin/user who added them

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User                 @relation(fields: [userId], references: [id])
  event Event?               @relation(fields: [eventId], references: [id])
  group ParticipationGroup?  @relation(fields: [groupId], references: [id])

  @@index([userId, from, to])
  @@index([userId, eventId])
  @@index([groupId])
}

model ParticipationImage {
  id      String @id @default(uuid())
  groupId String
  url     String
  caption String?

  createdAt DateTime @default(now())

  group ParticipationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model Activity {
  id                   String   @id @default(uuid())
  participationGroupId String
  name                 String
  from                 DateTime
  to                   DateTime
  location             String?
  locationUrl          String?
  involvedPeople       String[] // array of user IDs
  note                 String?
  imageUrl             String?
  sortOrder            Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String

  group ParticipationGroup @relation(fields: [participationGroupId], references: [id], onDelete: Cascade)
  media ActivityMedia[]

  @@index([participationGroupId])
  @@index([participationGroupId, from])
}

model ActivityMedia {
  id         String @id @default(uuid())
  activityId String
  url        String
  caption    String?
  uploadedBy String

  createdAt DateTime @default(now())

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
}

model Holiday {
  id          String   @id @default(uuid())
  date        DateTime
  description String?
  country     String?
  isGlobal    Boolean  @default(false)

  @@index([country])
}

model EventInvitee {
  id      String @id @default(uuid())
  eventId String
  userId  String

  createdAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId])
}

enum EventVisibility {
  PUBLIC
  PRIVATE
}

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
}

enum NotificationType {
  JOIN_REQUEST
  JOIN_REQUEST_APPROVED
  JOIN_REQUEST_REJECTED
  OWNERSHIP_TRANSFERRED
  USER_KICKED
  INVITED_TO_JOIN
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model ParticipationGroup {
  id      String  @id @default(uuid())
  eventId String?
  ownerId String
  name    String  @default("My Plan")

  isMemberInviteAllowed     Boolean @default(true)
  isPublic                  Boolean @default(false)
  isActivityPublicVisible   Boolean @default(true)
  isMemberListPublicVisible Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event          Event?               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  joinRequests   JoinRequest[]
  participations Participation[]
  activities     Activity[]
  images         ParticipationImage[]

  @@index([eventId])
  @@index([ownerId])
}

model JoinRequest {
  id      String            @id @default(uuid())
  groupId String
  userId  String
  status  JoinRequestStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group ParticipationGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User               @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@index([groupId, status])
}

model Notification {
  id     String           @id @default(uuid())
  userId String
  type   NotificationType
  data   Json
  isRead Boolean          @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
